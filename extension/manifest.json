{
  "manifest_version": 3,
  "name": "Vocab CE",
  "version": "0.1.0",
  "description": "Highlight any text to get an instant English explanation tailored for Vietnamese learners.",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "Open Vocab Bank",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": ["storage", "activeTab", "identity"],
  "host_permissions": ["http://localhost:8000/*", "http://127.0.0.1:8000/*"],
  "oauth2": {
    "client_id": "159800413643-lul5hk1id1e4hntiemvh0sov30blsg62.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  }
}
